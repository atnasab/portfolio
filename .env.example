# ── Django core ─────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=fetch-image-cage12
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://portfolio_user:strongpassword@localhost:5432/portfolio_db

# ── Email (SMTP — e.g. Gmail App Password or Mailgun) ───────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=zEmail
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
CONTACT_EMAIL=email@gmail.com

# ── Admin URL (obfuscate to reduce bot attacks) ──────────────────────────────
ADMIN_URL=my-secret-admin-2024/

# ── Sentry error tracking (optional but recommended) ────────────────────────
SENTRY_DSN=

# ── Google Analytics (optional) ─────────────────────────────────────────────
# Set this in the SiteProfile admin, not here
